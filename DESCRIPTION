Package: tinyoauth
Type: Package
Title: Minimal OAuth 2.0 Client
Version: 0.1.0
Date: 2026-06-10
Authors@R: c(
    person("Troy", "Hernandez", role = c("aut", "cre"),
           email = "troy@cornball.ai",
           comment = c(ORCID = "0009-0005-4248-604X")),
    person("Sounkou Mahamane", "Toure", role = "ctb",
           email = "sounkoutoure@gmail.com"),
